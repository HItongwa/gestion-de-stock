<%- include('../partials/header') %>
<div class="container">
  <h1>Modifier l'utilisateur</h1>
  <form method="POST" action="/utilisateurs/edit/<%= user.id %>">
    <label>Nom<input type="text" name="nom" value="<%= user.nom %>" required /></label>
    <label>Prénom<input type="text" name="prenom" value="<%= user.prenom || '' %>" /></label>
    <label>Email<input type="email" name="email" value="<%= user.email %>" required /></label>
    <label>Nouveau mot de passe (laisser vide pour ne pas changer)<input type="password" name="motDePasse" /></label>
    <label>Rôle
      <select name="roleId" required>
        <% roles.forEach(r => { %>
          <option value="<%= r.id %>" <%= r.id === user.roleId ? 'selected' : '' %>><%= r.nom %></option>
        <% }) %>
      </select>
    </label>
    <button type="submit">Mettre à jour</button>
    <a href="/utilisateurs">Annuler</a>
  </form>
</div>
<%- include('../partials/footer') %>
