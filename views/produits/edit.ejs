<%- include('../partials/header') %>
<div class="container">
  <h1>Modifier le produit</h1>
  <form method="POST" action="/produits/edit/<%= produit.id %>">
    <label>Nom<input type="text" name="nom" value="<%= produit.nom %>" required /></label>
    <label>Quantité<input type="number" name="quantite" value="<%= produit.quantite %>" min="0" /></label>
    <label>Prix<input type="number" name="prix" step="0.01" value="<%= produit.prix %>" required /></label>
    <label>Catégorie
      <select name="categorieId" required>
        <% categories.forEach(c => { %>
          <option value="<%= c.id %>" <%= c.id === produit.categorieId ? 'selected' : '' %>><%= c.nom %></option>
        <% }) %>
      </select>
    </label>
    <label>Fournisseur
      <select name="fournisseurId" required>
        <% fournisseurs.forEach(f => { %>
          <option value="<%= f.id %>" <%= f.id === produit.fournisseurId ? 'selected' : '' %>><%= f.nom %></option>
        <% }) %>
      </select>
    </label>
    <button type="submit">Mettre à jour</button>
    <a href="/produits">Annuler</a>
  </form>
</div>
<%- include('../partials/footer') %>
