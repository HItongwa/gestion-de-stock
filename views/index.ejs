<%- include('partials/header') %>
<div class="container">
  <h1>Tableau de bord</h1>
  <% if (locals.user) { %>
    <div class="cards">
      <div class="card"><h2><%= nbUtilisateurs %></h2><p>Utilisateurs</p></div>
      <div class="card"><h2><%= nbProduits %></h2><p>Produits</p></div>
      <div class="card"><h2><%= valeurStock %> $</h2><p>Valeur du stock</p></div>
      <div class="card alert"><h2><%= alerteStock %></h2><p>Alertes stock bas</p></div>
    </div>
  <% } else { %>
    <p>Veuillez <a href="/login">vous connecter</a> pour accéder au tableau de bord.</p>
  <% } %>
</div>
<%- include('partials/footer') %>
