<%- include('../partials/header') %>
<div class="container">
  <h1>Liste des Utilisateurs</h1>
  <a href="/utilisateurs/ajouter" class="btn">+ Ajouter un utilisateur</a>
  <table>
    <thead><tr><th>ID</th><th>Nom</th><th>Prénom</th><th>Email</th><th>Rôle</th><th>Actions</th></tr></thead>
    <tbody>
      <% users.forEach(u => { %>
      <tr>
        <td><%= u.id %></td>
        <td><%= u.nom %></td>
        <td><%= u.prenom || '' %></td>
        <td><%= u.email %></td>
        <td><%= u.Role ? u.Role.nom : 'N/A' %></td>
        <td>
          <a href="/utilisateurs/edit/<%= u.id %>">✏️</a>
          <a href="/utilisateurs/delete/<%= u.id %>" onclick="return confirm('Supprimer ?')">🗑️</a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
